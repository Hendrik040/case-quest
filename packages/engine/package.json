{
  "name": "@case-quest/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "e2e": "node scripts/e2e-drive.mjs && CQ_WORLD_URL=/worlds/case3-m5.world.json CQ_EXPECT_MEETINGS=4 node scripts/e2e-drive.mjs",
    "e2e:toy": "node scripts/e2e-drive.mjs",
    "e2e:meetings": "CQ_WORLD_URL=/worlds/case3-m5.world.json CQ_EXPECT_MEETINGS=4 node scripts/e2e-drive.mjs"
  },
  "dependencies": {
    "@case-quest/schema": "workspace:*",
    "phaser": "^3.90.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
